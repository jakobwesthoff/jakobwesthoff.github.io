---
import "../styles/global.css";
import { getImage } from "astro:assets";
import avatar from "../assets/avatar.png";
import { profile } from "../data/profile";
import { pages } from "../data/pages";

interface Props {
  title: string;
  description: string;
  bodyClass?: string;
  /** OpenGraph image URL. Falls back to a square render of the avatar. */
  image?: string;
  /** OpenGraph type: "website" for landing pages, "article" for content. */
  ogType?: string;
}

const { title, description, bodyClass, image, ogType = "website" } = Astro.props;

// The imprint is a legal obligation (§ 5 TMG), reachable from every page but
// kept visually subordinate. We omit the link on the imprint page itself, where
// it would link to the current page.
const isImprint = Astro.url.pathname.replace(/\/$/, "") === "/imprint";

const backgroundAvatar = await getImage({
  src: avatar,
  width: 40,
  height: 40,
  format: "webp",
  quality: 60,
});

// =========================================================
// Page metadata
// =========================================================

// Canonical and social-share metadata require absolute URLs, resolved against
// the `site` origin configured in astro.config.mjs.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Social preview image. Each page maps to a generated 1200x630 card at
// /open-graph/<slug>.png (see src/pages/open-graph). A caller-supplied `image`
// overrides it; unknown routes fall back to the homepage card.
const slug = Astro.url.pathname.replace(/^\/+|\/+$/g, "") || "index";

let ogImageSrc: string;
let ogImageDimensions: { width: number; height: number } | undefined;
if (image) {
  ogImageSrc = image;
} else {
  const cardSlug = slug in pages ? slug : "index";
  ogImageSrc = `/open-graph/${cardSlug}.png`;
  ogImageDimensions = { width: 1200, height: 630 };
}
const ogImageURL = new URL(ogImageSrc, Astro.site);

// A portrait of the person, distinct from the OG banner above. Used as the
// schema.org Person image, where a photo is the semantically correct choice.
const portrait = await getImage({ src: avatar, width: 512, height: 512, format: "png" });
const portraitURL = new URL(portrait.src, Astro.site);

// schema.org Person identity, emitted on every page. The social profiles double
// as `sameAs` links so search engines can reconcile the entity across the web.
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: profile.name,
  jobTitle: profile.jobTitle,
  url: Astro.site?.href,
  image: portraitURL.href,
  sameAs: profile.social.map((link) => link.href),
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={profile.name} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#F3AB27" />
    <link rel="canonical" href={canonicalURL.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- OpenGraph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:site_name" content={profile.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageURL.href} />
    {
      ogImageDimensions && (
        <>
          <meta property="og:image:width" content={String(ogImageDimensions.width)} />
          <meta property="og:image:height" content={String(ogImageDimensions.height)} />
        </>
      )
    }

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(personSchema)} />
  </head>
  <body
    class:list={[
      "pt-safe-top pb-safe-bottom pl-safe-left pr-safe-right relative flex min-h-dvh bg-[#F3AB27]",
      bodyClass,
    ]}
    style={`--bgImage: url(${backgroundAvatar.src})`}
  >
    {
      !isImprint && (
        <a
          href="/imprint"
          class="absolute top-4 right-4 z-20 text-[0.7rem] font-medium tracking-wider text-gray-900/35 uppercase transition-colors hover:text-gray-900/60"
        >
          Impressum
        </a>
      )
    }
    <slot />
  </body>
</html>
