---
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pages } from "../data/pages";

const projects = [
  {
    name: "ntropy",
    tagline: "Markdown notes for the AI era: a real query language, no database, no lock-in",
    color: "#2dd4bf",
    url: "https://ntropy.westhoffswelt.de",
  },
  {
    name: "DialogDetective",
    tagline: "AI-powered TV episode identification from dialogue",
    color: "#0ea5e9",
    url: "https://dialogdetective.westhoffswelt.de",
  },
  {
    name: "jlif",
    tagline:
      "A command-line tool for scanning multi-object JSON logs with syntax highlighting and filtering",
    color: "#f59e0b",
    url: "https://jlif.westhoffswelt.de",
  },
  {
    name: "podpull",
    tagline: "Download and sync podcasts from RSS feeds",
    color: "#7c3aed",
    url: "https://podpull.westhoffswelt.de",
  },
  {
    name: "TetroTime",
    tagline: "A terminal clock powered by the tetrominos from your childhood",
    color: "#ec4899",
    url: "https://tetrotime.westhoffswelt.de",
  },
  {
    name: "Random TAD",
    tagline: "Your next Star Trek podcast episode, chosen by fate",
    color: "#ef4444",
    url: "https://random-tad.de",
  },
  {
    name: "blendwerk",
    tagline: "File-based API mock HTTP/HTTPS server",
    color: "#22c55e",
    url: "https://blendwerk.westhoffswelt.de",
  },
  {
    name: "The Raytracer Challenge",
    tagline: "From book to browser: a Rust raytracer powered by WASM",
    color: "#2563eb",
    url: "https://raytracer.xyz",
  },
];

// The flagship shelf above is curated: each entry has its own landing page.
// These are the rest — real libraries, CLIs, and SDKs at every stage of
// maturity, presented as their source repos. A hand-picked taste of the
// breadth on GitHub and crates.io, not the full catalogue.
const smallProjects = [
  {
    name: "venturi",
    tagline: "A durable, PostgreSQL-backed job queue for Rust",
    url: "https://github.com/jakobwesthoff/venturi",
  },
  {
    name: "patine",
    tagline: "Render Markdown beautifully in the terminal",
    url: "https://github.com/jakobwesthoff/patine",
  },
  {
    name: "mkulid",
    tagline: "A command-line ULID generator, like uuidgen but for ULIDs",
    url: "https://github.com/jakobwesthoff/mkulid",
  },
  {
    name: "openepaperlink-rust-sdk",
    tagline: "A Rust SDK for OpenEPaperLink e-paper tags",
    url: "https://github.com/jakobwesthoff/openepaperlink-rust-sdk",
  },
  {
    name: "pixel_loop",
    tagline: "A self-stabilizing update loop drawing engine",
    url: "https://github.com/jakobwesthoff/pixel_loop",
  },
  {
    name: "prettytable.sh",
    tagline: "Pretty-print tabular data in the terminal",
    url: "https://github.com/jakobwesthoff/prettytable.sh",
  },
];
---

<BaseLayout
  title={pages.projects.title}
  description={pages.projects.description}
  bodyClass="flex-col"
>
  <!-- Back navigation -->
  <a
    href="/"
    class="absolute top-4 left-4 z-20 rounded-full bg-gray-900/10 px-4 py-2 text-sm font-medium text-gray-900 transition-colors hover:bg-gray-900/20"
  >
    &larr; Home
  </a>

  <div class="relative z-10 mx-auto w-full max-w-3xl px-6 pt-20 pb-12">
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-bold text-gray-900">
        Projects<span class="text-gray-900/30">*</span>
      </h1>
      <p class="mt-2 text-base text-gray-900/50 italic">*built between midnight and coffee</p>
    </div>

    <div class="flex flex-col gap-4">
      {
        projects.map((project, index) => (
          <a
            href={project.url}
            target="_blank"
            rel="noopener noreferrer"
            class="animate-fade-slide-up group block rounded-xl border border-white/30 bg-white/15 px-6 py-5 shadow-sm transition-all duration-200 hover:bg-white/25"
            style={`animation-delay: ${index * 0.07}s`}
          >
            <div class="flex flex-col items-start justify-between gap-1 sm:flex-row sm:items-center sm:gap-4">
              <span class="text-xl font-semibold text-gray-900" style={`color: ${project.color}`}>
                {project.name}
              </span>
              <span class="text-sm text-gray-700">{project.tagline}</span>
            </div>
          </a>
        ))
      }
    </div>

    <!-- Workshop floor: a bridge from the curated shelf to the full body of work -->
    <div class="animate-fade-slide-up mt-16" style="animation-delay: 0.6s">
      <div class="border-t border-white/30 pt-8">
        <h2 class="text-2xl font-bold text-gray-900">...and the workshop floor</h2>
        <p class="mt-2 text-sm text-gray-700">
          Not everything gets its own landing page. More libraries, CLIs, and SDKs live on GitHub
          and crates.io, some early-stage, others quietly shipping for years.
        </p>
      </div>

      <!-- Profile links: GitHub for everything, plus the package registries the
           work is published to (crates.io for Rust, npm for Node). -->
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href="https://github.com/jakobwesthoff"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-gray-900/10 px-4 py-2 text-sm font-medium text-gray-900 transition-colors hover:bg-gray-900/20"
        >
          <Icon name="fa6-brands:github" class="h-4 w-4" /> GitHub
        </a>
        <a
          href="https://crates.io/users/jakobwesthoff"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-gray-900/10 px-4 py-2 text-sm font-medium text-gray-900 transition-colors hover:bg-gray-900/20"
        >
          <Icon name="fa6-solid:cube" class="h-4 w-4" /> crates.io
        </a>
        <a
          href="https://www.npmjs.com/~jakobwesthoff"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-gray-900/10 px-4 py-2 text-sm font-medium text-gray-900 transition-colors hover:bg-gray-900/20"
        >
          <Icon name="fa6-brands:npm" class="h-4 w-4" /> npm
        </a>
      </div>

      <!-- A hand-picked taste. Monospace names mark these as raw repos, distinct
           from the flagship display names above. -->
      <div class="mt-6 rounded-xl border border-white/30 bg-white/10">
        {
          smallProjects.map((project) => (
            <a
              href={project.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col items-start justify-between gap-1 border-b border-white/20 px-4 py-3 transition-colors last:border-b-0 hover:bg-white/15 sm:flex-row sm:items-center sm:gap-4"
            >
              <span class="font-mono text-sm font-semibold text-gray-900">{project.name}</span>
              <span class="text-sm text-gray-700">{project.tagline}</span>
            </a>
          ))
        }
      </div>

      <a
        href="https://github.com/jakobwesthoff?tab=repositories"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-block text-sm font-medium text-gray-900/70 transition-colors hover:text-gray-900"
      >
        Browse all repositories on GitHub &rarr;
      </a>
    </div>
  </div>
</BaseLayout>
